# Copy to .env and adjust as needed. All values below are defaults.

# Directory where SQLite DB, FAISS indexes, and reference images are stored.
DATA_DIR=./data

# Comma-separated list of allowed CORS origins for the React dev server.
CORS_ORIGINS=http://localhost:5173

# Face matching: max cosine distance to count as a match (lower = stricter).
FACE_MATCH_THRESHOLD=0.35

# Product matching: min cosine similarity to count as a match (higher = stricter).
PRODUCT_MATCH_THRESHOLD=0.75
